{
  "name": "meco-platform",
  "version": "1.0.0",
  "description": "DigitalOcean-hosted API starter for the MECO Robotics operations app.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma db push"
  },
  "keywords": [
    "meco",
    "fastify",
    "digitalocean",
    "prisma"
  ],
  "author": "Codex",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
