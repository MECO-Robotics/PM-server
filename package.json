{
  "name": "meco-platform",
  "version": "1.0.0",
  "description": "DigitalOcean-hosted API starter for the MECO Robotics operations app.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "smtp:dev": "tsx watch scripts/dev-smtp.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test ./test/app.core-auth.test.ts ./test/app.inventory-artifacts-workstreams.test.ts ./test/app.inventory-manufacturing-purchases.test.ts ./test/app.planning-entities.test.ts ./test/app.tasks-events.test.ts ./test/app.work-logs.test.ts ./test/app.reports.test.ts ./test/authRosterAccess.test.ts ./test/devAuthBypass.test.ts ./test/emailAuth.test.ts ./test/env.test.ts ./test/requestLimits.test.ts ./test/slackHomeService.test.ts ./test/store.test.ts ./test/workflows.test.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "verify": "npm run typecheck && npm run test && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:normalize-event-types": "prisma db execute --schema prisma/schema.prisma --file prisma/sql/normalize-event-types.sql",
    "prisma:deploy": "prisma db push --skip-generate"
  },
  "keywords": [
    "meco",
    "fastify",
    "digitalocean",
    "prisma"
  ],
  "author": "Codex",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
