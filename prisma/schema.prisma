generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  STUDENT
  MENTOR
  ADMIN
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_FOR_QA
  COMPLETE
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum DisciplineCode {
  MECHANICAL
  ELECTRICAL
  SOFTWARE
  INTEGRATION
  QA_TEST
}

enum MilestoneType {
  PRACTICE
  COMPETITION
  DEADLINE
  INTERNAL_REVIEW
  DEMO
}

enum MilestoneStatus {
  NOT_READY
  BLOCKED
  QA
  READY
}

enum MoscowPriority {
  MUST
  SHOULD
  COULD
  WONT
}

enum RequirementStatus {
  PLANNED
  IN_PROGRESS
  COMPLETE
}

enum BlockerType {
  TASK_DEPENDENCY
  MANUFACTURING_DELAY
  SHIPPING_DELAY
  QA_FEEDBACK
  OTHER
}

enum ManufacturingProcess {
  PRINT_3D
  CNC
  FABRICATION
}

enum ManufacturingStatus {
  REQUESTED
  APPROVED
  IN_PROGRESS
  QA
  COMPLETE
}

enum PartInstanceStatus {
  NOT_READY
  BLOCKED
  QA
  READY
}

enum PurchaseStatus {
  REQUESTED
  APPROVED
  PURCHASED
  SHIPPED
  DELIVERED
}

enum QaResult {
  PASS
  MINOR_FIX
  ITERATION_WORTHY
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RsvpStatus {
  YES
  MAYBE
  NO
}

enum OnshapeAuthMode {
  API_KEY
  OAUTH
}

enum CadSyncLevel {
  LINK_ONLY
  SHALLOW
  BOM
  DEEP_RELEASE
}

enum CadImportSource {
  STEP_UPLOAD
  ONSHAPE_API
  ONSHAPE_BOM_CSV
  MANUAL_BOM_CSV
}

enum CadImportStatus {
  PENDING
  PARSING
  PARSED
  MAPPING_REVIEW
  MAPPED
  FINALIZED
  FAILED
  CANCELED
}

enum CadSnapshotStatus {
  parsed
  mapping_review
  mapped
  finalized
  superseded
}

enum CadSnapshotSource {
  MANUAL_SNAPSHOT
  DESIGN_REVIEW
  MANUFACTURING_RELEASE
  AS_BUILT
  SCHEDULED_CANDIDATE
}

enum CadMappingSourceKind {
  ASSEMBLY_NODE
  PART_DEFINITION
  PART_INSTANCE
}

enum CadMappingTargetKind {
  SUBSYSTEM
  MECHANISM
  COMPONENT_ASSEMBLY
  PART_DEFINITION
  PART_INSTANCE
  IGNORE
  REFERENCE_GEOMETRY
  UNMAPPED
}

enum CadMappingConfidence {
  HIGH
  MEDIUM
  LOW
  MANUAL
}

enum CadSnapshotMappingStatus {
  PROPOSED
  CONFIRMED
  REJECTED
  NEEDS_REVIEW
}

enum CadMappingMatchStrategy {
  STABLE_SIGNATURE
  INSTANCE_PATH
  NORMALIZED_NAME
  NORMALIZED_NAME_WITH_PARENT
  MANUAL_ONLY
}

enum CadAssemblyInferredType {
  ROOT
  SUBSYSTEM_CANDIDATE
  MECHANISM_CANDIDATE
  COMPONENT_ASSEMBLY_CANDIDATE
  SUBASSEMBLY
  UNKNOWN
}

enum CadWarningSeverity {
  INFO
  WARNING
  ERROR
}

enum OnshapePlanType {
  EDUCATION
  FREE
  STANDARD
  PROFESSIONAL
  ENTERPRISE
  UNKNOWN
}

model Member {
  id                        String              @id @default(cuid())
  name                      String
  role                      MemberRole
  ownedTasks                Task[]              @relation("TaskOwner")
  mentoredTasks             Task[]              @relation("TaskMentor")
  responsibleSubsystems     Subsystem[]         @relation("ResponsibleEngineer")
  subsystemMemberships      SubsystemMember[]
  subsystemMentorships      SubsystemMentor[]
  workLogParticipants       WorkLogParticipant[]
  attendanceRecords         AttendanceRecord[]
  rsvps                     RSVP[]
  requestedManufacturing    ManufacturingItem[] @relation("ManufacturingRequester")
  requestedPurchases        PurchaseItem[]      @relation("PurchaseRequester")
  approvedPurchases         PurchaseItem[]      @relation("PurchaseApprover")
  qaParticipants            QAParticipant[]
  mentorApprovedQaReviews   QAReview[]          @relation("QaMentorApprover")
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
}

model Subsystem {
  id                    String            @id @default(cuid())
  name                  String            @unique
  color                 String?
  description           String?
  isCore                Boolean           @default(false)
  parentSubsystemId     String?
  parentSubsystem       Subsystem?        @relation("SubsystemParent", fields: [parentSubsystemId], references: [id])
  childSubsystems       Subsystem[]       @relation("SubsystemParent")
  responsibleEngineerId String
  responsibleEngineer   Member            @relation("ResponsibleEngineer", fields: [responsibleEngineerId], references: [id])
  mechanisms            Mechanism[]
  requirements          Requirement[]
  partInstances         PartInstance[]
  tasks                 Task[]
  manufacturingItems    ManufacturingItem[]
  purchaseItems         PurchaseItem[]
  members               SubsystemMember[]
  mentors               SubsystemMentor[]
  risks                 Risk[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Discipline {
  id        String         @id @default(cuid())
  code      DisciplineCode @unique
  name      String         @unique
  tasks     Task[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Mechanism {
  id           String         @id @default(cuid())
  subsystemId  String
  name         String
  description  String?
  subsystem    Subsystem      @relation(fields: [subsystemId], references: [id])
  partInstances PartInstance[]
  tasks        Task[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Requirement {
  id             String            @id @default(cuid())
  subsystemId    String
  title          String
  description    String
  moscowPriority MoscowPriority
  status         RequirementStatus @default(PLANNED)
  subsystem      Subsystem         @relation(fields: [subsystemId], references: [id])
  tasks          Task[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model PartDefinition {
  id                 String             @id @default(cuid())
  seasonId           String
  activeSeasonIds    String[]
  name               String
  partNumber         String             @unique
  revision           String
  type               String
  source             String
  partInstances      PartInstance[]
  manufacturingItems ManufacturingItem[] @relation("ManufacturingPartDefinition")
  purchaseItems      PurchaseItem[]      @relation("PurchasePartDefinition")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model PartInstance {
  id                String         @id @default(cuid())
  partDefinitionId  String
  subsystemId       String
  mechanismId       String?
  name              String
  quantity          Int            @default(1)
  trackIndividually Boolean        @default(false)
  status            PartInstanceStatus @default(NOT_READY)
  partDefinition    PartDefinition @relation(fields: [partDefinitionId], references: [id])
  subsystem         Subsystem      @relation(fields: [subsystemId], references: [id])
  mechanism         Mechanism?     @relation(fields: [mechanismId], references: [id])
  tasks             Task[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model SubsystemMember {
  subsystemId String
  memberId    String
  subsystem   Subsystem @relation(fields: [subsystemId], references: [id])
  member      Member    @relation(fields: [memberId], references: [id])

  @@id([subsystemId, memberId])
}

model SubsystemMentor {
  subsystemId String
  memberId    String
  subsystem   Subsystem @relation(fields: [subsystemId], references: [id])
  member      Member    @relation(fields: [memberId], references: [id])

  @@id([subsystemId, memberId])
}

model Task {
  id                      String                @id @default(cuid())
  title                   String
  description             String
  dueDate                 DateTime?
  priority                TaskPriority
  status                  TaskStatus            @default(NOT_STARTED)
  estimatedHours          Float?
  actualHours             Float?
  requiresDocumentation   Boolean               @default(true)
  documentationUrl        String?
  subsystemId             String
  disciplineId            String
  requirementId           String?
  mechanismId             String?
  partInstanceId          String?
  targetMilestoneId         String?
  ownerId                 String
  assigneeIds             String[]
  mentorId                String
  parentTaskId            String?
  subsystem               Subsystem             @relation(fields: [subsystemId], references: [id])
  discipline              Discipline            @relation(fields: [disciplineId], references: [id])
  requirement             Requirement?          @relation(fields: [requirementId], references: [id])
  mechanism               Mechanism?            @relation(fields: [mechanismId], references: [id])
  partInstance            PartInstance?         @relation(fields: [partInstanceId], references: [id])
  targetMilestone           Milestone?            @relation(fields: [targetMilestoneId], references: [id])
  owner                   Member                @relation("TaskOwner", fields: [ownerId], references: [id])
  mentor                  Member                @relation("TaskMentor", fields: [mentorId], references: [id])
  parentTask              Task?                 @relation("TaskIterations", fields: [parentTaskId], references: [id])
  iterationTasks          Task[]                @relation("TaskIterations")
  workLogs                WorkLog[]
  qaReviews               QAReview[]
  blockers                TaskBlocker[]
  dependencies            TaskDependency[]      @relation("TaskDependsOn")
  dependentTasks          TaskDependency[]      @relation("TaskRequiredBy")
  manufacturingLinks      TaskManufacturingItem[]
  purchaseLinks           TaskPurchaseItem[]
  riskLinks               RiskTask[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
}

model Milestone {
  id                 String    @id @default(cuid())
  title              String
  type               MilestoneType
  status             MilestoneStatus @default(NOT_READY)
  startDateTime      DateTime
  endDateTime        DateTime?
  isExternal         Boolean   @default(false)
  description        String?
  projectIds         String[]
  relatedSubsystemIds String[]
  tasks              Task[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model TaskDependency {
  predecessorId String
  successorId   String
  predecessor   Task   @relation("TaskRequiredBy", fields: [predecessorId], references: [id])
  successor     Task   @relation("TaskDependsOn", fields: [successorId], references: [id])

  @@id([predecessorId, successorId])
}

model TaskBlocker {
  id         String      @id @default(cuid())
  taskId     String
  type       BlockerType
  summary    String
  isResolved Boolean     @default(false)
  task       Task        @relation(fields: [taskId], references: [id])
  createdAt  DateTime    @default(now())
}

model WorkLog {
  id           String               @id @default(cuid())
  taskId       String
  loggedAt     DateTime
  hours        Float
  notes        String?
  task         Task                 @relation(fields: [taskId], references: [id])
  participants WorkLogParticipant[]
  createdAt    DateTime             @default(now())
}

model WorkLogParticipant {
  workLogId String
  memberId  String
  workLog   WorkLog @relation(fields: [workLogId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])

  @@id([workLogId, memberId])
}

model Meeting {
  id                String             @id @default(cuid())
  title             String
  scheduledAt       DateTime
  attendanceRecords AttendanceRecord[]
  rsvps             RSVP[]
  createdAt         DateTime           @default(now())
}

model RSVP {
  id        String     @id @default(cuid())
  meetingId String
  memberId  String
  status    RsvpStatus
  meeting   Meeting    @relation(fields: [meetingId], references: [id])
  member    Member     @relation(fields: [memberId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([meetingId, memberId])
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  meetingId   String
  memberId    String
  signedInAt  DateTime
  signedOutAt DateTime?
  totalHours  Float
  notes       String?
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
  member      Member   @relation(fields: [memberId], references: [id])

  @@unique([meetingId, memberId])
}

model ManufacturingBatch {
  id        String               @id @default(cuid())
  label     String               @unique
  dueDate   DateTime?
  material  String?
  process   ManufacturingProcess?
  items     ManufacturingItem[]
  createdAt DateTime             @default(now())
}

model ManufacturingItem {
  id                String                @id @default(cuid())
  title             String
  dueDate           DateTime?
  priority          TaskPriority?
  material          String?
  materialId        String?
  partDefinitionId  String?
  quantity          Int                   @default(1)
  mentorReviewed    Boolean               @default(false)
  inHouse           Boolean               @default(true)
  process           ManufacturingProcess
  status            ManufacturingStatus   @default(REQUESTED)
  subsystemId       String
  requestedById     String
  batchId           String?
  subsystem         Subsystem             @relation(fields: [subsystemId], references: [id])
  requestedBy       Member                @relation("ManufacturingRequester", fields: [requestedById], references: [id])
  batch             ManufacturingBatch?   @relation(fields: [batchId], references: [id])
  partDefinition    PartDefinition?       @relation("ManufacturingPartDefinition", fields: [partDefinitionId], references: [id])
  qaReviews         QAReview[]
  taskLinks         TaskManufacturingItem[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model TaskManufacturingItem {
  taskId              String
  manufacturingItemId String
  task                Task              @relation(fields: [taskId], references: [id])
  manufacturingItem   ManufacturingItem @relation(fields: [manufacturingItemId], references: [id])

  @@id([taskId, manufacturingItemId])
}

model PurchaseItem {
  id               String             @id @default(cuid())
  title            String
  vendor           String?
  link             String?
  quantity         Int                @default(1)
  estimatedCost    Float?
  finalCost        Float?
  status           PurchaseStatus     @default(REQUESTED)
  subsystemId      String
  requestedById    String
  partDefinitionId String?
  approvedById     String?
  approvedAt       DateTime?
  purchasedAt      DateTime?
  deliveredAt      DateTime?
  subsystem        Subsystem          @relation(fields: [subsystemId], references: [id])
  requestedBy      Member             @relation("PurchaseRequester", fields: [requestedById], references: [id])
  approvedBy       Member?            @relation("PurchaseApprover", fields: [approvedById], references: [id])
  partDefinition   PartDefinition?    @relation("PurchasePartDefinition", fields: [partDefinitionId], references: [id])
  taskLinks        TaskPurchaseItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model TaskPurchaseItem {
  taskId         String
  purchaseItemId String
  task           Task         @relation(fields: [taskId], references: [id])
  purchaseItem   PurchaseItem @relation(fields: [purchaseItemId], references: [id])

  @@id([taskId, purchaseItemId])
}

model QAReview {
  id                  String             @id @default(cuid())
  taskId              String?
  manufacturingItemId String?
  result              QaResult
  notes               String?
  mentorApproved      Boolean            @default(false)
  mentorApproverId    String?
  reviewedAt          DateTime           @default(now())
  task                Task?              @relation(fields: [taskId], references: [id])
  manufacturingItem   ManufacturingItem? @relation(fields: [manufacturingItemId], references: [id])
  mentorApprover      Member?            @relation("QaMentorApprover", fields: [mentorApproverId], references: [id])
  participants        QAParticipant[]
}

model QAParticipant {
  qaReviewId String
  memberId   String
  qaReview   QAReview @relation(fields: [qaReviewId], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])

  @@id([qaReviewId, memberId])
}

model Risk {
  id          String       @id @default(cuid())
  subsystemId String
  title       String
  description String?
  severity    RiskSeverity @default(MEDIUM)
  subsystem   Subsystem    @relation(fields: [subsystemId], references: [id])
  taskLinks   RiskTask[]
  createdAt   DateTime     @default(now())
}

model RiskTask {
  riskId String
  taskId String
  risk   Risk @relation(fields: [riskId], references: [id])
  task   Task @relation(fields: [taskId], references: [id])

  @@id([riskId, taskId])
}

model OnshapeConnection {
  id                  String          @id @default(cuid())
  organizationId      String?
  authMode            OnshapeAuthMode @default(API_KEY)
  credentialReference String?
  baseUrl             String          @default("https://cad.onshape.com")
  disabledAt          DateTime?
  lastError           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model OnshapeDocumentRef {
  id                 String         @id @default(cuid())
  projectId          String?
  seasonId           String?
  subsystemId        String?
  mechanismId        String?
  label              String
  documentId         String
  workspaceId        String?
  versionId          String?
  microversionId     String?
  elementId          String?
  originalUrl        String
  parsedUrlJson      Json
  createdBy          String?
  importRuns         CadImportRun[]
  snapshots          CadSnapshot[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([documentId])
  @@index([workspaceId])
  @@index([versionId])
  @@index([microversionId])
  @@index([elementId])
  @@index([createdAt])
}

model CadImportRun {
  id                   String              @id @default(cuid())
  projectId            String?
  seasonId             String?
  source               CadImportSource
  status               CadImportStatus     @default(PENDING)
  originalFilename     String
  uploadedFileId       String?
  uploadedFileHash     String?
  parserVersion        String?
  parseStartedAt       DateTime?
  parseCompletedAt     DateTime?
  requestedBy          String?
  errorMessage         String?
  rawSummaryJson       Json
  onshapeDocumentRefId String?
  syncLevel            CadSyncLevel?
  callsEstimated       Int?
  callsUsed            Int                 @default(0)
  stoppedReason        String?
  documentRef          OnshapeDocumentRef? @relation(fields: [onshapeDocumentRefId], references: [id])
  requestLogs          OnshapeApiRequestLog[]
  snapshots            CadSnapshot[]
  warnings             CadImportWarning[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([projectId])
  @@index([seasonId])
  @@index([source])
  @@index([onshapeDocumentRefId])
  @@index([status])
  @@index([createdAt])
}

model OnshapeApiRequestLog {
  id                   String        @id @default(cuid())
  importRunId          String?
  endpoint             String
  method               String
  cacheKey             String
  usedCache            Boolean       @default(false)
  statusCode           Int?
  requestStartedAt     DateTime      @default(now())
  requestCompletedAt   DateTime?
  responseHeadersJson  Json
  rateLimitRemaining   Int?
  errorMessage         String?
  importRun            CadImportRun? @relation(fields: [importRunId], references: [id])

  @@index([importRunId])
  @@index([cacheKey])
  @@index([requestStartedAt])
}

model OnshapeApiCacheEntry {
  id                  String   @id @default(cuid())
  cacheKey            String   @unique
  endpoint            String
  method              String
  requestHash         String
  responseJson        Json
  responseHeadersJson Json
  documentId          String?
  workspaceId         String?
  versionId           String?
  microversionId      String?
  elementId           String?
  immutable           Boolean  @default(false)
  createdAt           DateTime @default(now())
  expiresAt           DateTime?

  @@index([documentId])
  @@index([workspaceId])
  @@index([versionId])
  @@index([microversionId])
  @@index([elementId])
  @@index([createdAt])
}

model CadSnapshot {
  id                   String              @id @default(cuid())
  projectId            String?
  seasonId             String?
  importRunId          String
  source               CadImportSource
  label                String
  uploadedFileId       String?
  uploadedFileHash     String?
  previousSnapshotId   String?
  status               CadSnapshotStatus    @default(parsed)
  createdBy            String?
  finalizedBy          String?
  finalizedAt          DateTime?
  notes                String?
  subsystemId          String?
  mechanismId          String?
  onshapeDocumentRefId String?
  snapshotSource       CadSnapshotSource?
  documentId           String?
  workspaceId          String?
  versionId            String?
  microversionId       String?
  elementId            String?
  immutable            Boolean             @default(true)
  documentRef          OnshapeDocumentRef?  @relation(fields: [onshapeDocumentRefId], references: [id])
  importRun            CadImportRun         @relation(fields: [importRunId], references: [id])
  previousSnapshot     CadSnapshot?         @relation("CadSnapshotHistory", fields: [previousSnapshotId], references: [id])
  nextSnapshots        CadSnapshot[]        @relation("CadSnapshotHistory")
  assemblyNodes        CadAssemblyNode[]
  partDefinitions      CadPartDefinition[]
  partInstances        CadPartInstance[]
  mappings             CadSnapshotMapping[]
  mappingRules         CadMappingRule[]     @relation("CadRuleSourceSnapshot")
  warnings             CadImportWarning[]
  createdAt            DateTime             @default(now())

  @@index([projectId])
  @@index([seasonId])
  @@index([source])
  @@index([status])
  @@index([onshapeDocumentRefId])
  @@index([importRunId])
  @@index([documentId])
  @@index([elementId])
  @@index([createdAt])
}

model CadAssemblyNode {
  id                    String                  @id @default(cuid())
  snapshotId            String
  sourceId              String
  parentSourceId        String?
  parentAssemblyNodeId  String?
  name                  String
  normalizedName        String
  instancePath          String
  depth                 Int
  inferredType          CadAssemblyInferredType @default(UNKNOWN)
  stableSignature       String
  metadataJson          Json
  documentId            String?
  elementId             String?
  assemblyInstanceId    String?
  subsystemId           String?
  mechanismId           String?
  snapshot              CadSnapshot             @relation(fields: [snapshotId], references: [id])
  parentAssemblyNode    CadAssemblyNode?         @relation("CadAssemblyTree", fields: [parentAssemblyNodeId], references: [id])
  childAssemblyNodes    CadAssemblyNode[]        @relation("CadAssemblyTree")
  partInstances         CadPartInstance[]        @relation("CadAssemblyPartInstances")
  createdAt             DateTime                @default(now())

  @@unique([snapshotId, sourceId])
  @@index([snapshotId])
  @@index([stableSignature])
  @@index([normalizedName])
  @@index([documentId])
  @@index([elementId])
}

model CadPartDefinition {
  id                         String              @id @default(cuid())
  snapshotId                 String
  sourceId                   String
  name                       String
  normalizedName             String
  partNumber                 String?
  material                   String?
  stableSignature            String
  metadataJson               Json
  documentId                 String?
  elementId                  String?
  partId                     String?
  versionId                  String?
  microversionId             String?
  mass                       Float?
  configuration              String?
  customPropertiesJson       Json?
  metadataHash               String?
  missionControlExternalKey  String?
  snapshot                   CadSnapshot         @relation(fields: [snapshotId], references: [id])
  instances                  CadPartInstance[]
  createdAt                  DateTime            @default(now())

  @@unique([snapshotId, sourceId])
  @@index([snapshotId])
  @@index([stableSignature])
  @@index([partNumber])
  @@index([normalizedName])
  @@index([documentId])
  @@index([elementId])
  @@index([partId])
}

model CadPartInstance {
  id                   String             @id @default(cuid())
  snapshotId           String
  sourceId             String
  partDefinitionId     String?
  parentAssemblyNodeId String?
  instancePath         String
  quantity             Int                @default(1)
  stableSignature      String
  metadataJson         Json
  documentId           String?
  elementId            String?
  assemblyInstanceId   String?
  partId               String?
  suppressed           Boolean?
  configuration        String?
  transformJson        Json?
  snapshot             CadSnapshot        @relation(fields: [snapshotId], references: [id])
  cadPartDefinition    CadPartDefinition? @relation(fields: [partDefinitionId], references: [id])
  parentAssemblyNode   CadAssemblyNode?   @relation("CadAssemblyPartInstances", fields: [parentAssemblyNodeId], references: [id])
  createdAt            DateTime           @default(now())

  @@unique([snapshotId, sourceId])
  @@index([snapshotId])
  @@index([stableSignature])
  @@index([parentAssemblyNodeId])
  @@index([partDefinitionId])
  @@index([documentId])
  @@index([elementId])
  @@index([partId])
}

model CadMappingRule {
  id                    String                  @id @default(cuid())
  projectId             String
  seasonId              String?
  sourceKind            CadMappingSourceKind
  matchStrategy         CadMappingMatchStrategy
  matchValue            String
  targetKind            CadMappingTargetKind
  targetId              String?
  confidence            CadMappingConfidence
  createdFromSnapshotId String
  createdBy             String?
  createdAt             DateTime                @default(now())
  supersededByRuleId    String?
  active                Boolean                 @default(true)
  notes                 String?
  createdFromSnapshot   CadSnapshot             @relation("CadRuleSourceSnapshot", fields: [createdFromSnapshotId], references: [id])
  supersededByRule      CadMappingRule?         @relation("CadRuleSupersession", fields: [supersededByRuleId], references: [id])
  supersededRules       CadMappingRule[]        @relation("CadRuleSupersession")
  snapshotMappings      CadSnapshotMapping[]

  @@index([projectId])
  @@index([seasonId])
  @@index([sourceKind])
  @@index([matchStrategy, matchValue])
  @@index([targetKind, targetId])
  @@index([active])
}

model CadSnapshotMapping {
  id            String                   @id @default(cuid())
  snapshotId    String
  mappingRuleId String?
  sourceKind    CadMappingSourceKind
  sourceId      String
  targetKind    CadMappingTargetKind
  targetId      String?
  confidence    CadMappingConfidence
  status        CadSnapshotMappingStatus
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  snapshot      CadSnapshot              @relation(fields: [snapshotId], references: [id])
  mappingRule   CadMappingRule?          @relation(fields: [mappingRuleId], references: [id])

  @@unique([snapshotId, sourceKind, sourceId])
  @@index([snapshotId])
  @@index([mappingRuleId])
  @@index([targetKind, targetId])
  @@index([status])
}

model CadImportWarning {
  id            String                @id @default(cuid())
  importRunId   String
  snapshotId    String?
  severity      CadWarningSeverity
  code          String
  title         String
  message       String
  sourceKind    CadMappingSourceKind?
  sourceId      String?
  metadataJson  Json
  importRun     CadImportRun          @relation(fields: [importRunId], references: [id])
  snapshot      CadSnapshot?          @relation(fields: [snapshotId], references: [id])
  createdAt     DateTime              @default(now())

  @@index([importRunId])
  @@index([snapshotId])
  @@index([sourceKind, sourceId])
  @@index([code])
  @@index([createdAt])
}

model OnshapeApiBudget {
  id                       String          @id @default(cuid())
  organizationId           String?
  planType                 OnshapePlanType @default(EDUCATION)
  annualCallBudget         Int?
  monthlyCallBudget        Int?
  dailySoftBudget          Int?
  perSyncSoftBudget        Int?
  callsUsedToday           Int             @default(0)
  callsUsedThisMonth       Int             @default(0)
  callsUsedThisYear        Int             @default(0)
  warningThresholdPercent  Int             @default(70)
  hardStopThresholdPercent Int             @default(90)
  lastResetAt              DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([organizationId])
  @@index([createdAt])
}
